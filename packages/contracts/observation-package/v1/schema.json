{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dronewatch.local/contracts/observation-package/v1/schema.json",
  "title": "DroneWatch Observation Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageId",
    "sourceType",
    "packageKind",
    "createdAt",
    "captureSession",
    "humanReport",
    "evidence",
    "derivedEvidence",
    "validationJoin",
    "privacy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "observation_package.v1"
    },
    "packageId": {
      "type": "string",
      "minLength": 1
    },
    "sourceType": {
      "const": "civilian_report"
    },
    "packageKind": {
      "const": "observation_package"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "captureSession": {
      "$ref": "#/$defs/captureSession"
    },
    "humanReport": {
      "$ref": "#/$defs/humanReport"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "derivedEvidence": {
      "$ref": "#/$defs/derivedEvidence"
    },
    "validationJoin": {
      "$ref": "#/$defs/validationJoin"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    }
  },
  "$defs": {
    "captureSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captureSessionId",
        "startedAt",
        "endedAt",
        "appPlatform",
        "captureMode"
      ],
      "properties": {
        "captureSessionId": {
          "type": "string",
          "minLength": 1
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        },
        "appPlatform": {
          "type": "string",
          "enum": ["ios", "android", "web", "unknown"]
        },
        "captureMode": {
          "type": "string",
          "enum": ["guided_camera", "manual_report"]
        },
        "device": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "deviceClass": {
              "type": "string"
            },
            "osVersion": {
              "type": "string"
            },
            "appVersion": {
              "type": "string"
            }
          }
        }
      }
    },
    "humanReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observationType", "observerConfidence"],
      "properties": {
        "observationType": {
          "type": "string",
          "enum": ["possible_drone", "unknown_airborne_object", "other"]
        },
        "observerConfidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "countEstimate": {
          "type": "integer",
          "minimum": 1
        },
        "note": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tracking", "motion"],
      "properties": {
        "tracking": {
          "$ref": "#/$defs/tracking"
        },
        "motion": {
          "$ref": "#/$defs/motion"
        },
        "camera": {
          "$ref": "#/$defs/camera"
        },
        "audio": {
          "$ref": "#/$defs/audio"
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trackingStatus",
        "durationMs",
        "frameCount",
        "boundingBoxTrace",
        "continuityScore",
        "targetLostEvents",
        "reacquisitionEvents"
      ],
      "properties": {
        "trackingStatus": {
          "type": "string",
          "enum": ["tracked", "weak", "lost", "not_available"]
        },
        "targetTrackId": {
          "type": "string"
        },
        "trackStartedAt": {
          "type": "string",
          "format": "date-time"
        },
        "trackEndedAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "frameCount": {
          "type": "integer",
          "minimum": 0
        },
        "boundingBoxTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundingBoxSample"
          }
        },
        "continuityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "targetLostEvents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/trackEvent"
          }
        },
        "reacquisitionEvents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/trackEvent"
          }
        }
      }
    },
    "trackEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "enum": ["out_of_frame", "low_contrast", "occluded", "tracker_uncertain", "unknown"]
        }
      }
    },
    "boundingBoxSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "box"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "box": {
          "$ref": "#/$defs/normalizedBox"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "normalizedBox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["devicePoseTrace"],
      "properties": {
        "devicePoseTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/devicePoseSample"
          }
        },
        "bearingEstimate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["degrees", "source"],
          "properties": {
            "degrees": {
              "type": "number",
              "minimum": 0,
              "maximum": 360
            },
            "source": {
              "type": "string",
              "enum": ["device_heading", "derived_track", "observer_declared"]
            },
            "uncertaintyDegrees": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "gyroscopeTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/axisSample"
          }
        },
        "accelerometerTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/axisSample"
          }
        },
        "motionSummary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apparentDirection": {
              "type": "string",
              "enum": ["left_to_right", "right_to_left", "upward", "downward", "stationary", "unclear"]
            },
            "stability": {
              "type": "string",
              "enum": ["stable", "some_jitter", "unstable"]
            },
            "headingStabilityScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "motionSmoothnessScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "devicePoseSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "headingDegrees": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "pitchDegrees": {
          "type": "number"
        },
        "rollDegrees": {
          "type": "number"
        }
      }
    },
    "axisSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "x", "y", "z"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captured"],
      "properties": {
        "captured": {
          "type": "boolean"
        },
        "sampleWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startedAt", "endedAt"],
          "properties": {
            "startedAt": {
              "type": "string",
              "format": "date-time"
            },
            "endedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "levelSummaryDb": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": {
                  "type": "number"
                },
                "mean": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                }
              }
            },
            "dominantFrequencyHz": {
              "type": "number",
              "minimum": 0
            },
            "signalToNoiseRatioDb": {
              "type": "number"
            },
            "bandEnergy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "low": {
                  "type": "number"
                },
                "mid": {
                  "type": "number"
                },
                "high": {
                  "type": "number"
                }
              }
            },
            "noiseProxy": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "windProxy": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "quality": {
          "type": "string",
          "enum": ["usable", "noisy", "not_usable"]
        }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cameraDevice", "cameraSummary", "zoomTrace"],
      "properties": {
        "cameraDevice": {
          "type": "object",
          "additionalProperties": false,
          "required": ["position", "lensClass", "physicalLensSwitchingSupported"],
          "properties": {
            "position": {
              "type": "string",
              "enum": ["back", "front", "unknown"]
            },
            "lensClass": {
              "type": "string",
              "enum": ["wide", "telephoto", "digital_fallback", "unknown"]
            },
            "physicalLensSwitchingSupported": {
              "type": "boolean"
            }
          }
        },
        "cameraSummary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minZoomFactor",
            "maxZoomFactor",
            "finalZoomFactor",
            "lensSwitchCount",
            "usedPhysicalLensSwitching",
            "usedDigitalFallback"
          ],
          "properties": {
            "minZoomFactor": {
              "type": "number",
              "minimum": 1
            },
            "maxZoomFactor": {
              "type": "number",
              "minimum": 1
            },
            "finalZoomFactor": {
              "type": "number",
              "minimum": 1
            },
            "lensSwitchCount": {
              "type": "integer",
              "minimum": 0
            },
            "usedPhysicalLensSwitching": {
              "type": "boolean"
            },
            "usedDigitalFallback": {
              "type": "boolean"
            }
          }
        },
        "zoomTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/zoomSample"
          }
        }
      }
    },
    "zoomSample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "effectiveZoomFactor",
        "requestedZoomFactor",
        "lensClass",
        "digitalZoomFactor",
        "digitalFallback"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "effectiveZoomFactor": {
          "type": "number",
          "minimum": 1
        },
        "requestedZoomFactor": {
          "type": "number",
          "minimum": 1
        },
        "lensClass": {
          "type": "string",
          "enum": ["wide", "telephoto", "digital_fallback", "unknown"]
        },
        "digitalZoomFactor": {
          "type": "number",
          "minimum": 1
        },
        "digitalFallback": {
          "type": "boolean"
        },
        "preset": {
          "type": "string"
        }
      }
    },
    "derivedEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qualityScore",
        "qualityTier",
        "qualitySignals",
        "reasonCodes",
        "insufficiencyReasons",
        "featureFlags",
        "mlReadiness"
      ],
      "properties": {
        "qualityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "qualityTier": {
          "type": "string",
          "enum": ["strong", "moderate", "weak", "insufficient"]
        },
        "qualitySignals": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "continuityScore",
            "visualConfidence",
            "headingConfidence",
            "motionStability"
          ],
          "properties": {
            "continuityScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "visualConfidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "headingConfidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "motionStability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sufficient_continuous_track",
              "stable_heading",
              "observer_location_available",
              "audio_supporting_evidence",
              "audio_not_required",
              "duration_below_strong",
              "tracking_too_short",
              "continuity_low",
              "tracking_lost",
              "low_visual_confidence",
              "no_location",
              "unstable_heading",
              "poor_device_motion",
              "audio_unavailable",
              "observer_low_confidence"
            ]
          }
        },
        "insufficiencyReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tracking_too_short",
              "continuity_low",
              "tracking_lost",
              "low_visual_confidence",
              "no_location",
              "unstable_heading",
              "poor_device_motion",
              "audio_unavailable",
              "observer_low_confidence"
            ]
          }
        },
        "featureFlags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hasBoundingBoxTrace",
            "hasDevicePoseTrace",
            "hasObserverLocation",
            "hasAudioFeatures"
          ],
          "properties": {
            "hasBoundingBoxTrace": {
              "type": "boolean"
            },
            "hasCameraZoomTrace": {
              "type": "boolean"
            },
            "hasDevicePoseTrace": {
              "type": "boolean"
            },
            "hasObserverLocation": {
              "type": "boolean"
            },
            "hasAudioFeatures": {
              "type": "boolean"
            }
          }
        },
        "mlReadiness": {
          "type": "string",
          "enum": ["ready", "partial", "not_ready"]
        },
        "compactFeatureSummary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "durationMs": {
              "type": "integer",
              "minimum": 0
            },
            "frameCount": {
              "type": "integer",
              "minimum": 0
            },
            "bearingDegrees": {
              "type": "number",
              "minimum": 0,
              "maximum": 360
            },
            "locationAccuracyMeters": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "validationJoin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeWindow"],
      "properties": {
        "timeWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startedAt", "endedAt"],
          "properties": {
            "startedAt": {
              "type": "string",
              "format": "date-time"
            },
            "endedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "observerLocation": {
          "$ref": "#/$defs/location"
        },
        "spatialUncertaintyMeters": {
          "type": "number",
          "minimum": 0
        },
        "roughBearingDegrees": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "joinKeys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "geohash": {
              "type": "string"
            },
            "timeBucket": {
              "type": "string"
            }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon", "source"],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "accuracyMeters": {
          "type": "number",
          "minimum": 0
        },
        "source": {
          "type": "string",
          "enum": ["device_gps", "manual", "unknown"]
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["containsRawMedia", "retentionPolicy", "locationPrecision"],
      "properties": {
        "containsRawMedia": {
          "type": "boolean"
        },
        "retentionPolicy": {
          "type": "string",
          "enum": ["metadata_only", "short_term_review", "retain_for_validation"]
        },
        "locationPrecision": {
          "type": "string",
          "enum": ["exact", "reduced", "none"]
        }
      }
    }
  }
}

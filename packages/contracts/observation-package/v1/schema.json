{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dronewatch.local/contracts/observation-package/v1/schema.json",
  "title": "DroneWatch Observation Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageId",
    "sourceType",
    "packageKind",
    "createdAt",
    "captureSession",
    "humanReport",
    "evidence",
    "derivedEvidence",
    "validationJoin",
    "privacy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "observation_package.v1"
    },
    "packageId": {
      "type": "string",
      "minLength": 1
    },
    "sourceType": {
      "const": "civilian_report"
    },
    "packageKind": {
      "const": "observation_package"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "captureSession": {
      "$ref": "#/$defs/captureSession"
    },
    "humanReport": {
      "$ref": "#/$defs/humanReport"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "derivedEvidence": {
      "$ref": "#/$defs/derivedEvidence"
    },
    "validationJoin": {
      "$ref": "#/$defs/validationJoin"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    }
  },
  "$defs": {
    "captureSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captureSessionId",
        "startedAt",
        "endedAt",
        "appPlatform",
        "captureMode"
      ],
      "properties": {
        "captureSessionId": {
          "type": "string",
          "minLength": 1
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        },
        "appPlatform": {
          "type": "string",
          "enum": ["ios", "android", "web", "unknown"]
        },
        "captureMode": {
          "type": "string",
          "enum": ["guided_camera", "manual_report"]
        },
        "device": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "deviceClass": {
              "type": "string"
            },
            "osVersion": {
              "type": "string"
            },
            "appVersion": {
              "type": "string"
            }
          }
        }
      }
    },
    "humanReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observationType", "observerConfidence"],
      "properties": {
        "observationType": {
          "type": "string",
          "enum": ["possible_drone", "unknown_airborne_object", "other"]
        },
        "observerConfidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "countEstimate": {
          "type": "integer",
          "minimum": 1
        },
        "note": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tracking", "motion"],
      "properties": {
        "tracking": {
          "$ref": "#/$defs/tracking"
        },
        "motion": {
          "$ref": "#/$defs/motion"
        },
        "audio": {
          "$ref": "#/$defs/audio"
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trackingStatus",
        "durationMs",
        "frameCount",
        "boundingBoxTrace"
      ],
      "properties": {
        "trackingStatus": {
          "type": "string",
          "enum": ["tracked", "weak", "lost", "not_available"]
        },
        "targetTrackId": {
          "type": "string"
        },
        "trackStartedAt": {
          "type": "string",
          "format": "date-time"
        },
        "trackEndedAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "frameCount": {
          "type": "integer",
          "minimum": 0
        },
        "boundingBoxTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundingBoxSample"
          }
        }
      }
    },
    "boundingBoxSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "box"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "box": {
          "$ref": "#/$defs/normalizedBox"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "normalizedBox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["devicePoseTrace"],
      "properties": {
        "devicePoseTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/devicePoseSample"
          }
        },
        "bearingEstimate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["degrees", "source"],
          "properties": {
            "degrees": {
              "type": "number",
              "minimum": 0,
              "maximum": 360
            },
            "source": {
              "type": "string",
              "enum": ["device_heading", "derived_track", "observer_declared"]
            },
            "uncertaintyDegrees": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "motionSummary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apparentDirection": {
              "type": "string",
              "enum": ["left_to_right", "right_to_left", "upward", "downward", "stationary", "unclear"]
            },
            "stability": {
              "type": "string",
              "enum": ["stable", "some_jitter", "unstable"]
            }
          }
        }
      }
    },
    "devicePoseSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "headingDegrees": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "pitchDegrees": {
          "type": "number"
        },
        "rollDegrees": {
          "type": "number"
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captured"],
      "properties": {
        "captured": {
          "type": "boolean"
        },
        "sampleWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startedAt", "endedAt"],
          "properties": {
            "startedAt": {
              "type": "string",
              "format": "date-time"
            },
            "endedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dominantFrequencyHz": {
              "type": "number",
              "minimum": 0
            },
            "signalToNoiseRatioDb": {
              "type": "number"
            }
          }
        },
        "quality": {
          "type": "string",
          "enum": ["usable", "noisy", "not_usable"]
        }
      }
    },
    "derivedEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qualityScore",
        "qualityTier",
        "insufficiencyReasons",
        "featureFlags",
        "mlReadiness"
      ],
      "properties": {
        "qualityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "qualityTier": {
          "type": "string",
          "enum": ["strong", "usable", "weak", "insufficient"]
        },
        "insufficiencyReasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tracking_too_short",
              "tracking_lost",
              "low_visual_confidence",
              "no_location",
              "poor_device_motion",
              "audio_unavailable",
              "observer_low_confidence"
            ]
          }
        },
        "featureFlags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hasBoundingBoxTrace",
            "hasDevicePoseTrace",
            "hasObserverLocation",
            "hasAudioFeatures"
          ],
          "properties": {
            "hasBoundingBoxTrace": {
              "type": "boolean"
            },
            "hasDevicePoseTrace": {
              "type": "boolean"
            },
            "hasObserverLocation": {
              "type": "boolean"
            },
            "hasAudioFeatures": {
              "type": "boolean"
            }
          }
        },
        "mlReadiness": {
          "type": "string",
          "enum": ["ready", "partial", "not_ready"]
        }
      }
    },
    "validationJoin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeWindow"],
      "properties": {
        "timeWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startedAt", "endedAt"],
          "properties": {
            "startedAt": {
              "type": "string",
              "format": "date-time"
            },
            "endedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "observerLocation": {
          "$ref": "#/$defs/location"
        },
        "spatialUncertaintyMeters": {
          "type": "number",
          "minimum": 0
        },
        "roughBearingDegrees": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "joinKeys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "geohash": {
              "type": "string"
            },
            "timeBucket": {
              "type": "string"
            }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon", "source"],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lon": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "accuracyMeters": {
          "type": "number",
          "minimum": 0
        },
        "source": {
          "type": "string",
          "enum": ["device_gps", "manual", "unknown"]
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["containsRawMedia", "retentionPolicy", "locationPrecision"],
      "properties": {
        "containsRawMedia": {
          "type": "boolean"
        },
        "retentionPolicy": {
          "type": "string",
          "enum": ["metadata_only", "short_term_review", "retain_for_validation"]
        },
        "locationPrecision": {
          "type": "string",
          "enum": ["exact", "reduced", "none"]
        }
      }
    }
  }
}

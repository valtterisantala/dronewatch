# Sample DJI iOS bootstrap state input for local verification.
# Replace these values with output produced by the direct iOS DJI Mobile SDK probe.

DJI_SDK_MANAGER_STATE=ready
DJI_REGISTRATION_STATE=success
DJI_BASE_PRODUCT_CONNECTED=true
DJI_CONNECTED_PRODUCT_CLASS=AIRCRAFT
DJI_CONNECTED_PRODUCT_MODEL=Mavic_Air_2

# Space-separated allowlist.
DJI_SUPPORTED_PRODUCT_CLASSES="AIRCRAFT"
